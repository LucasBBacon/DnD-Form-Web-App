{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "DnD Feat",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^feat_[a-z0-9_]+$"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "origin",
        "general",
        "epic_boon"
      ]
    },
    "source": {
      "type": "string"
    },
    "repeatable": {
      "type": "boolean"
    },
    "prerequisites": {
      "type": "object",
      "properties": {
        "minimumLevel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "abilityMinimums": {
          "type": "object",
          "properties": {
            "str": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30
            },
            "dex": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30
            },
            "con": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30
            },
            "int": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30
            },
            "wis": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30
            },
            "cha": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30
            }
          },
          "additionalProperties": false
        },
        "requiredFeatIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^feat_[a-z0-9_]+$"
          }
        },
        "requiredClassIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^class_[a-z0-9_]+$"
          }
        },
        "requiredSubclassIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^subclass_[a-z0-9_]+$"
          }
        },
        "requiredRaceIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^race_[a-z0-9_]+$"
          }
        },
        "requiredSubraceIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^subrace_[a-z0-9_]+$"
          }
        },
        "requiresSpellcasting": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "grantedTraits": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^trait_[a-z0-9_]+$"
      }
    },
    "lore": {
      "type": "object",
      "properties": {
        "shortDescription": {
          "type": "string"
        },
        "fullText": {
          "type": "string"
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "body"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "shortDescription"
      ],
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "name",
    "category",
    "grantedTraits",
    "lore"
  ],
  "additionalProperties": false
}