{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "$id": "definitions.json",
    "title": "Shared DnD Type Definitions",
    "description": "Reusable type definitions referenced by other schemas via $ref. Mirrors the union types in src/types/common.ts.",
    "definitions": {
        "AbilityScore": {
            "type": "string",
            "enum": [
                "str",
                "dex",
                "con",
                "int",
                "wis",
                "cha"
            ],
            "description": "One of the six D&D ability scores."
        },
        "AbilityBonusFixed": {
            "type": "object",
            "properties": {
                "str": {
                    "type": "integer"
                },
                "dex": {
                    "type": "integer"
                },
                "con": {
                    "type": "integer"
                },
                "int": {
                    "type": "integer"
                },
                "wis": {
                    "type": "integer"
                },
                "cha": {
                    "type": "integer"
                }
            },
            "additionalProperties": false
        },
        "AbilityBonusChoiceGrant": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer",
                    "description": "Number of ability scores to assign this bonus to."
                },
                "bonus": {
                    "type": "integer",
                    "description": "The bonus amount to assign."
                },
                "options": {
                    "type": "array",
                    "items": {
                        "$ref": "definitions.json#/definitions/AbilityScore"
                    },
                    "description": "Ability scores eligible for this bonus. If omitted, all six scores are valid."
                }
            },
            "required": [
                "count",
                "bonus"
            ]
        },
        "AbilityBonuses": {
            "type": "object",
            "description": "Fixed and player-selected ability score bonuses.",
            "properties": {
                "fixed": {
                    "$ref": "definitions.json#/definitions/AbilityBonusFixed"
                },
                "choices": {
                    "type": "array",
                    "description": "An ordered list of bonus assignments the player must make. Each entry is a separate bonus grant (e.g., one +2 and one +1 for Tasha's, or two +1s for Half-Elf).",
                    "items": {
                        "$ref": "definitions.json#/definitions/AbilityBonusChoiceGrant"
                    }
                }
            }
        },
        "Skill": {
            "type": "string",
            "enum": [
                "acrobatics",
                "animal_handling",
                "arcana",
                "athletics",
                "deception",
                "history",
                "insight",
                "intimidation",
                "investigation",
                "medicine",
                "nature",
                "perception",
                "performance",
                "persuasion",
                "religion",
                "sleight_of_hand",
                "stealth",
                "survival"
            ],
            "description": "A D&D 5e skill identifier."
        },
        "Size": {
            "type": "string",
            "enum": [
                "tiny",
                "small",
                "medium",
                "large"
            ],
            "description": "A creature size category."
        },
        "HitDie": {
            "type": "integer",
            "enum": [
                6,
                8,
                10,
                12
            ],
            "description": "Valid hit die face values (d6, d8, d10, d12)."
        },
        "SpellcastingAbility": {
            "type": "string",
            "enum": [
                "int",
                "wis",
                "cha"
            ],
            "description": "Ability scores that can be used as a spellcasting ability."
        }
    }
}