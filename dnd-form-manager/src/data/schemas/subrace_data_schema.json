{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "DnD Subrace",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^subrace_[a-z0-9_]+$",
      "description": "Unique identifier for the subrace."
    },
    "name": {
      "type": "string",
      "description": "Display name of the subrace"
    },
    "parentRaceId": {
      "type": "string",
      "description": "REQUIRED. Links back to the parent class."
    },
    "traitsAdded": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lore": {
      "type": "object",
      "properties": {
        "shortDescription": {
          "type": "string",
          "description": "A quick 1-2 sentence summary for tooltips."
        },
        "fullText": {
          "type": "string",
          "description": "The main body of text for the entity."
        },
        "sections": {
          "type": "array",
          "description": "Flexible key-value pairs for categorized flavor text (Age, Alignment, Lore, etc.).",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "body"
            ]
          }
        }
      },
      "required": [
        "shortDescription"
      ]
    }
  },
  "required": [
    "id",
    "name",
    "parentRaceId",
    "traitsAdded",
    "lore"
  ]
}