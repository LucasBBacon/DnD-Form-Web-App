{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "DnD Item Category",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^category_[a-z0-9_]+$",
      "description": "Unique identifier for the category."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name of the category."
    },
    "itemIds": {
      "type": "array",
      "description": "Item IDs belonging to this category.",
      "items": {
        "type": "string",
        "pattern": "^item_[a-z0-9_]+$"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "id",
    "name",
    "itemIds"
  ],
  "additionalProperties": false
}
