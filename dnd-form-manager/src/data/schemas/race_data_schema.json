{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "DnD Base Race",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^race_[a-z0-9_]+$",
      "description": "Unique identifier for the race."
    },
    "name": {
      "type": "string",
      "description": "Display name of the race"
    },
    "size": {
      "$ref": "definitions.json#/definitions/Size",
      "description": "The creature's size category."
    },
    "speed": {
      "type": "object",
      "properties": {
        "walk": {
          "type": "integer",
          "description": "Base walking speed in feet."
        },
        "fly": {
          "type": "integer",
          "default": 0
        },
        "swim": {
          "type": "integer",
          "default": 0
        },
        "climb": {
          "type": "integer",
          "default": 0
        }
      },
      "required": [
        "walk"
      ]
    },
    "abilityBonuses": {
      "$ref": "definitions.json#/definitions/AbilityBonuses"
    },
    "languages": {
      "type": "object",
      "properties": {
        "known": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of language IDs granted automatically."
        },
        "choices": {
          "type": "object",
          "properties": {
            "count": {
              "type": "integer",
              "description": "Number of additional languages the player can choose."
            },
            "uniqueChoices": {
              "type": "boolean"
            }
          }
        }
      },
      "required": [
        "known"
      ]
    },
    "traits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of Trait IDs referencing the external traits file (e.g., 'trait_fey_ancestry')."
    },
    "subraceInfo": {
      "type": [
        "object",
        "null"
      ],
      "description": "If null, this race has no subraces. If present, forces a choice.",
      "properties": {
        "optionsPool": {
          "type": "string",
          "description": "e.g., 'subraces_elf'"
        }
      }
    },
    "lore": {
      "type": "object",
      "properties": {
        "shortDescription": {
          "type": "string",
          "description": "A quick 1-2 sentence summary for tooltips."
        },
        "fullText": {
          "type": "string",
          "description": "The main body of text for the entity."
        },
        "sections": {
          "type": "array",
          "description": "Flexible key-value pairs for categorized flavor text (Age, Alignment, Lore, etc.).",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "body"
            ]
          }
        }
      },
      "required": [
        "shortDescription"
      ]
    }
  },
  "required": [
    "id",
    "name",
    "size",
    "speed",
    "abilityBonuses",
    "languages",
    "lore"
  ]
}