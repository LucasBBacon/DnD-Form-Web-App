{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "DnD Base Race",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^race_[a-z0-9_]+$",
      "description": "Unique identifier for the race."
    },
    "name": {
      "type": "string",
      "description": "Display name of the race"
    },
    "traits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of Trait IDs referencing the external traits file (e.g., 'trait_fey_ancestry')."
    },
    "subraceInfo": {
      "type": [
        "object",
        "null"
      ],
      "description": "If null, this race has no subraces. If present, metadata is provided for subrace UI labeling.",
      "properties": {
        "displayLabel": {
          "type": "string",
          "description": "e.g., 'Draconic Ancestry'"
        }
      }
    },
    "lore": {
      "type": "object",
      "properties": {
        "shortDescription": {
          "type": "string",
          "description": "A quick 1-2 sentence summary for tooltips."
        },
        "fullText": {
          "type": "string",
          "description": "The main body of text for the entity."
        },
        "sections": {
          "type": "array",
          "description": "Flexible key-value pairs for categorized flavor text (Age, Alignment, Lore, etc.).",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "body"
            ]
          }
        }
      },
      "required": [
        "shortDescription"
      ]
    }
  },
  "required": [
    "id",
    "name",
    "traits",
    "lore"
  ]
}