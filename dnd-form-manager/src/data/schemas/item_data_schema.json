{
	"$schema": "https://json-schema.org/draft-07/schema#",
	"title": "DnD Item",
	"type": "object",
	"properties": {
		"id": {
			"type": "string",
			"pattern": "^item_[a-z0-9_]+$",
			"description": "Unique identifier for the item."
		},
		"name": {
			"type": "string",
			"description": "Display name of the item."
		},
		"type": {
			"type": "string",
			"enum": [
				"gear",
				"weapon",
				"armor",
				"tool",
				"magic_item"
			],
			"description": "High-level item category."
		},
		"weight": {
			"type": "number",
			"minimum": 0,
			"description": "Item weight in pounds."
		},
		"cpCost": {
			"type": "number",
			"minimum": 0,
			"description": "Item cost in copper pieces."
		},
		"lore": {
			"type": "object",
			"properties": {
				"shortDescription": {
					"type": "string",
					"description": "A quick 1-2 sentence summary for tooltips."
				},
				"fullText": {
					"type": "string",
					"description": "The main body of text for the item."
				}
			},
			"required": [
				"shortDescription"
			]
		},
		"stacking": {
			"type": "object",
			"properties": {
				"mode": {
					"type": "string",
					"enum": [
						"stack",
						"instance"
					],
					"description": "How this item is represented in inventory state."
				},
				"bundleSize": {
					"type": "number",
					"minimum": 1,
					"description": "Default purchase/display bundle size for this item (e.g. arrows are listed in packs of 20)."
				},
				"maxBundleCount": {
					"type": "number",
					"minimum": 1,
					"description": "Optional practical stack cap for UI or optional rules modes."
				}
			},
			"required": [
				"mode"
			]
		},
		"armorProperties": {
			"type": "object",
			"properties": {
				"acApplication": {
					"type": "string",
					"enum": [
						"set",
						"bonus"
					],
					"description": "How this armor contributes to AC: sets a base AC or adds a bonus."
				},
				"armorType": {
					"type": "string",
					"enum": [
						"light",
						"medium",
						"heavy",
						"shield"
					],
					"description": "Armor category."
				},
				"baseAc": {
					"type": "number",
					"description": "Base Armor Class granted by the armor."
				},
				"dexModifier": {
					"type": "object",
					"properties": {
						"mode": {
							"type": "string",
							"enum": [
								"full",
								"capped",
								"none"
							],
							"description": "How Dexterity modifier contributes to AC for this armor."
						},
						"cap": {
							"type": "number",
							"description": "Maximum Dexterity modifier applied when mode is capped."
						}
					},
					"required": [
						"mode"
					],
					"allOf": [
						{
							"if": {
								"properties": {
									"mode": {
										"const": "capped"
									}
								},
								"required": [
									"mode"
								]
							},
							"then": {
								"required": [
									"cap"
								]
							}
						}
					]
				},
				"stealthDisadvantage": {
					"type": "boolean",
					"description": "Whether this armor imposes disadvantage on Stealth checks."
				},
				"strengthRequirement": {
					"type": "number",
					"description": "Minimum Strength score required to avoid speed penalties."
				}
			},
			"required": [
				"acApplication",
				"armorType",
				"baseAc",
				"dexModifier",
				"stealthDisadvantage"
			]
		},
		"weaponProperties": {
			"type": "object",
			"properties": {
				"category": {
					"type": "string",
					"enum": [
						"simple_melee",
						"martial_melee",
						"simple_ranged",
						"martial_ranged"
					],
					"description": "Weapon category used for proficiency and classification."
				},
				"damageDice": {
					"type": "string",
					"description": "Damage dice expression, e.g. 1d8."
				},
				"versatileDamageDice": {
					"type": "string",
					"description": "Optional two-handed damage dice for versatile weapons, e.g. 1d10."
				},
				"damageType": {
					"type": "string",
					"description": "Damage type dealt by the weapon, e.g. slashing."
				},
				"properties": {
					"type": "array",
					"items": {
						"type": "string",
						"enum": [
							"finesse",
							"light",
							"heavy",
							"two-handed",
							"thrown",
							"ammunition",
							"versatile",
							"reach",
							"loading"
						]
					},
					"description": "Rules properties associated with this weapon."
				},
				"range": {
					"type": "string",
					"description": "Range string such as 5 ft or 150/600 ft."
				},
				"ammoItemId": {
					"type": "string",
					"pattern": "^item_[a-z0-9_]+$",
					"description": "ID of item required as ammunition, if any."
				}
			},
			"required": [
				"category",
				"damageDice",
				"damageType",
				"properties",
				"range"
			]
		},
		"magicItemProperties": {
			"type": "object",
			"properties": {
				"bonusToAttack": {
					"type": "number",
					"description": "Flat bonus applied to attack rolls."
				},
				"bonusToDamage": {
					"type": "number",
					"description": "Flat bonus applied to damage rolls."
				},
				"bonusToAc": {
					"type": "number",
					"description": "Flat bonus applied to armor class calculations."
				},
				"requiresAttunement": {
					"type": "boolean",
					"description": "Whether this item requires attunement before bonuses apply."
				}
			},
			"required": [
				"requiresAttunement"
			]
		}
	},
	"required": [
		"id",
		"name",
		"type",
		"weight",
		"cpCost",
		"lore"
	],
	"allOf": [
		{
			"if": {
				"properties": {
					"type": {
						"const": "armor"
					}
				},
				"required": [
					"type"
				]
			},
			"then": {
				"required": [
					"armorProperties"
				]
			},
			"else": {
				"not": {
					"required": [
						"armorProperties"
					]
				}
			}
		},
		{
			"if": {
				"properties": {
					"type": {
						"const": "weapon"
					}
				},
				"required": [
					"type"
				]
			},
			"then": {
				"required": [
					"weaponProperties"
				]
			},
			"else": {
				"not": {
					"required": [
						"weaponProperties"
					]
				}
			}
		}
	]
}