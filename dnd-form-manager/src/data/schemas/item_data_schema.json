{
	"$schema": "https://json-schema.org/draft-07/schema#",
	"title": "DnD Item",
	"type": "object",
	"properties": {
		"id": {
			"type": "string",
			"pattern": "^item_[a-z0-9_]+$",
			"description": "Unique identifier for the item."
		},
		"name": {
			"type": "string",
			"description": "Display name of the item."
		},
		"type": {
			"type": "string",
			"enum": [
				"gear",
				"weapon",
				"armor",
				"tool",
				"magic_item"
			],
			"description": "High-level item category."
		},
		"weight": {
			"type": "number",
			"minimum": 0,
			"description": "Item weight in pounds."
		},
		"lore": {
			"type": "object",
			"properties": {
				"shortDescription": {
					"type": "string",
					"description": "A quick 1-2 sentence summary for tooltips."
				},
				"fullText": {
					"type": "string",
					"description": "The main body of text for the item."
				}
			},
			"required": [
				"shortDescription"
			]
		},
		"armorProperties": {
			"type": "object",
			"properties": {
				"armorType": {
					"type": "string",
					"enum": [
						"light",
						"medium",
						"heavy",
						"shield"
					],
					"description": "Armor category."
				},
				"baseAc": {
					"type": "number",
					"description": "Base Armor Class granted by the armor."
				},
				"stealthDisadvantage": {
					"type": "boolean",
					"description": "Whether this armor imposes disadvantage on Stealth checks."
				},
				"strengthRequirement": {
					"type": "number",
					"description": "Minimum Strength score required to avoid speed penalties."
				}
			},
			"required": [
				"armorType",
				"baseAc",
				"stealthDisadvantage"
			]
		},
		"weaponProperties": {
			"type": "object",
			"properties": {
				"category": {
					"type": "string",
					"enum": [
						"simple_melee",
						"martial_melee",
						"simple_ranged",
						"martial_ranged"
					],
					"description": "Weapon category used for proficiency and classification."
				},
				"damageDice": {
					"type": "string",
					"description": "Damage dice expression, e.g. 1d8."
				},
				"damageType": {
					"type": "string",
					"description": "Damage type dealt by the weapon, e.g. slashing."
				},
				"properties": {
					"type": "array",
					"items": {
						"type": "string",
						"enum": [
							"finesse",
							"light",
							"heavy",
							"two-handed",
							"thrown",
							"ammunition",
							"versatile",
							"reach"
						]
					},
					"description": "Rules properties associated with this weapon."
				},
				"range": {
					"type": "string",
					"description": "Range string such as 5 ft or 150/600 ft."
				},
				"ammoItemId": {
					"type": "string",
					"pattern": "^item_[a-z0-9_]+$",
					"description": "ID of item required as ammunition, if any."
				}
			},
			"required": [
				"category",
				"damageDice",
				"damageType",
				"properties",
				"range"
			]
		}
	},
	"required": [
		"id",
		"name",
		"type",
		"weight",
		"lore"
	],
	"allOf": [
		{
			"if": {
				"properties": {
					"type": {
						"const": "armor"
					}
				},
				"required": [
					"type"
				]
			},
			"then": {
				"required": [
					"armorProperties"
				]
			},
			"else": {
				"not": {
					"required": [
						"armorProperties"
					]
				}
			}
		},
		{
			"if": {
				"properties": {
					"type": {
						"const": "weapon"
					}
				},
				"required": [
					"type"
				]
			},
			"then": {
				"required": [
					"weaponProperties"
				]
			},
			"else": {
				"not": {
					"required": [
						"weaponProperties"
					]
				}
			}
		}
	]
}