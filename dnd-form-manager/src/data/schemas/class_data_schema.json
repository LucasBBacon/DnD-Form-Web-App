{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "DnD Class",
  "description": "",
  "type": "object",
  "definitions": {
    "EquipmentReference": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "item"
            },
            "refId": {
              "type": "string",
              "pattern": "^item_[a-z0-9_]+$"
            },
            "quantity": {
              "type": "integer",
              "minimum": 1
            },
            "condition": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "refId",
            "quantity"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "category"
            },
            "refId": {
              "type": "string",
              "pattern": "^category_[a-z0-9_]+$"
            },
            "quantity": {
              "type": "integer",
              "minimum": 1
            },
            "condition": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "refId",
            "quantity"
          ],
          "additionalProperties": false
        }
      ]
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^class_[a-z0-9_]+$",
      "description": "Unique identifier for the class."
    },
    "name": {
      "type": "string"
    },
    "hitDie": {
      "$ref": "definitions.json#/definitions/HitDie",
      "description": "Faces of the hit die (e.g., 8 for d8)."
    },
    "multiclassTraits": {
      "type": "array",
      "description": "Trait IDs granted when this class is taken as a secondary (multiclass) class.",
      "items": {
        "type": "string",
        "pattern": "^trait_[a-z0-9_]+$"
      }
    },
    "startingEquipment": {
      "type": "object",
      "properties": {
        "given": {
          "type": "array",
          "description": "Items the class always starts with.",
          "items": {
            "$ref": "#/definitions/EquipmentReference"
          }
        },
        "choices": {
          "type": "array",
          "description": "An array of choice groups (e.g., Bullet point 1, Bullet point 2).",
          "items": {
            "type": "object",
            "properties": {
              "choose": {
                "type": "integer",
                "description": "How many options the user can pick from this group (typically 1)."
              },
              "options": {
                "type": "array",
                "description": "The mutually exclusive options. Each option is a bundle object containing an array of items.",
                "items": {
                  "type": "object",
                  "properties": {
                    "equipmentBundle": {
                      "type": "array",
                      "description": "A set of items granted together as a single choice.",
                      "items": {
                        "$ref": "#/definitions/EquipmentReference"
                      }
                    }
                  },
                  "required": [
                    "equipmentBundle"
                  ]
                }
              }
            },
            "required": [
              "choose",
              "options"
            ]
          }
        }
      }
    },
    "subclassInfo": {
      "type": "object",
      "properties": {
        "choiceLevel": {
          "type": "integer",
          "description": "The level at which this class chooses a subclass."
        },
        "optionsPool": {
          "type": "string",
          "description": "Identifier to query valid subclasses (e.g., 'subclasses_rogue')"
        }
      }
    },
    "progression": {
      "type": "array",
      "description": "Exactly 20 objects representing levels 1 through 20, in order. Index 0 = level 1, index 19 = level 20.",
      "minItems": 20,
      "maxItems": 20,
      "items": {
        "type": "object",
        "properties": {
          "level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "description": "The class level this entry represents (1–20)."
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Trait IDs granted at this level (e.g. 'trait_action_surge')."
          },
          "classSpecificScaling": {
            "type": "object",
            "description": "Custom key-value pairs for class-specific resources (e.g., Sneak Attack damage, Ki points).",
            "additionalProperties": {
              "type": [
                "array",
                "string",
                "integer",
                "number"
              ]
            }
          },
          "spellcastingProgression": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "cantripsKnown": {
                "type": "integer",
                "minimum": 0
              },
              "spellsKnown": {
                "type": "integer",
                "minimum": 0
              },
              "spellSlots": {
                "type": "object",
                "description": "Mapping of spell level (1-9) to number of slots available.",
                "patternProperties": {
                  "^[1-9]$": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "level",
          "features"
        ],
        "additionalProperties": false
      }
    },
    "lore": {
      "type": "object",
      "properties": {
        "shortDescription": {
          "type": "string",
          "description": "A quick 1-2 sentence summary for tooltips."
        },
        "fullText": {
          "type": "string",
          "description": "The main body of text for the entity."
        },
        "sections": {
          "type": "array",
          "description": "Flexible key-value pairs for categorized flavor text (Age, Alignment, Lore, etc.).",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "body"
            ]
          }
        }
      },
      "required": [
        "shortDescription"
      ]
    }
  },
  "required": [
    "id",
    "name",
    "hitDie",
    "subclassInfo",
    "progression"
  ]
}