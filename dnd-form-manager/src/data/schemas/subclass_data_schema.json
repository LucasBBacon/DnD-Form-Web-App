{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "DnD Subclass",
    "description": "",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^subclass_[a-z0-9_]+$",
            "description": "Unique identifier for the subclass."
        },
        "name": {
            "type": "string"
        },
        "parentClassId": {
            "type": "string",
            "description": "The Id of the base class this belongs to (e.g., 'class_rogue')"
        },
        "spellcastingOverride": {
            "type": [
                "object",
                "null"
            ],
            "description": "Used if the subclass introduces spellcasting to a martial class, or changes the base class casting rules.",
            "properties": {
                "ability": {
                    "type": "string",
                    "enum": [
                        "int",
                        "wis",
                        "cha"
                    ]
                },
                "preparationType": {
                    "type": "string",
                    "enum": [
                        "known",
                        "prepared",
                        "pact"
                    ]
                },
                "schoolRestrictions": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "abjuration",
                            "conjuration",
                            "divination",
                            "enchantment",
                            "evocation",
                            "illusion",
                            "necromancy",
                            "transmutation"
                        ]
                    },
                    "description": "Array of valid spell schools for 1/3 casters. Leave empty if no restrictions apply."
                }
            }
        },
        "progression": {
            "type": "array",
            "description": "An ordered list of subclass progression entries. Include only levels where this subclass grants features.",
            "items": {
                "type": "object",
                "properties": {
                    "level": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 20,
                        "description": "The character level this subclass entry applies to (1-20)."
                    },
                    "features": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Trait IDs granted at this specific level."
                    },
                    "subclassSpecificScaling": {
                        "type": "object",
                        "description": "Subclass scaling key-value pairs where each key maps to a scalar value. During runtime resolution, entries from higher character levels override lower-level values for the same key. Known stat keys currently consumed by useCharacterStats include: initiative, initiative_bonus, ac, armor_class, speed.",
                        "additionalProperties": {
                            "type": [
                                "string",
                                "integer",
                                "number"
                            ]
                        }
                    },
                    "bonusSpells": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Spell IDs automatically learned or prepared at this level."
                    },
                    "spellsAddedToList": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Spell IDs added to the class spell list for optional selection."
                    },
                    "spellcastingProgressionAdditions": {
                        "type": [
                            "object",
                            "null"
                        ],
                        "description": "Spellcasting progression adjustments granted at this level (separate from subclassSpecificScaling, which is generic scalar progression data).",
                        "properties": {
                            "cantripsKnown": {
                                "type": "integer"
                            },
                            "spellsKnown": {
                                "type": "integer"
                            },
                            "spellSlots": {
                                "type": "object",
                                "description": "Mapping of spell level (1-9) to number of slots available.",
                                "additionalProperties": {
                                    "type": "integer"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "level",
                    "features"
                ]
            }
        },
        "lore": {
            "type": "object",
            "properties": {
                "shortDescription": {
                    "type": "string",
                    "description": "A quick 1-2 sentence summary for tooltips."
                },
                "fullText": {
                    "type": "string",
                    "description": "The main body of text for the entity."
                },
                "sections": {
                    "type": "array",
                    "description": "Flexible key-value pairs for categorized flavor text (Age, Alignment, Lore, etc.).",
                    "items": {
                        "type": "object",
                        "properties": {
                            "title": {
                                "type": "string"
                            },
                            "body": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "title",
                            "body"
                        ]
                    }
                }
            },
            "required": [
                "shortDescription"
            ]
        }
    },
    "required": [
        "id",
        "name",
        "parentClassId",
        "progression"
    ]
}