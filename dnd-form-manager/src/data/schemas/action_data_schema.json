{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "DnD Action",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^action_[a-z0-9_]+$",
            "description": "Unique identifier for the action."
        },
        "name": {
            "type": "string",
            "description": "Display name of the action."
        },
        "description": {
            "type": "string",
            "description": "Detailed description of the action's effects and usage."
        },
        "activation": {
            "type": "object",
            "description": "Defines the action economy cost and any triggers.",
            "properties": {
                "actionType": {
                    "type": "string",
                    "enum": ["action", "bonus_action", "reaction", "legendary_action", "special", "minute", "hour"],
                    "description": "The type of action (e.g., 'action', 'bonus_action', 'reaction')."
                },
                "condition": {
                    "type": "string",
                    "description": "Required for reactions (e.g., 'When you take damage')."
                }
            },
            "required": ["actionType"]
        },
        "range": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["self", "touch", "ranged", "sight", "unlimited"]
                },
                "distance": {
                    "type": "integer",
                    "description": "Range in feet. Null if touch or self"
                },
                "maxDistance": {
                    "type": "integer",
                    "description": "Long range for weapons (e.g., 120 for a shortbow)."
                }
            }
        },
        "areaOfEffect": {
            "type": "object",
            "description": "Optional. Defines if the action hits an area.",
            "properties": {
                "shape": {
                    "type": "string",
                    "enum": ["cone", "cube", "cylinder", "line", "sphere"]
                },
                "size": {
                    "type": "integer",
                    "description": "Size in feet."
                }
            },
            "required": ["shape", "size"]
        },
        "attackRoll": {
            "type": "object",
            "description": "Optional. Present if the action requires an attack roll.",
            "properties": {
                "ability": {
                    "type": "string",
                    "enum": ["str", "dex", "con", "int", "wis", "cha", "finesse", "spellcasting"],
                    "description": "The ability modifier to use. 'finesse' lets the engine pick the higher of STR or DEX. 'spellcasting' uses the character's spellcasting ability."
                },
                "includeProficiency": {
                    "type": "boolean",
                    "default": true
                }
            },
            "required": ["ability"]
        },
        "savingThrow": {
            "type": "object",
            "description": "Optional. Present if the action forces a saving throw.",
            "properties": {
                "ability": {
                    "type": "string",
                    "enum": ["str", "dex", "con", "int", "wis", "cha"]
                },
                "dcCalculation": {
                    "type": "object",
                    "properties": {
                        "base": {
                            "type": "integer",
                            "default": 8
                        },
                        "includeProficiency": {
                            "type": "boolean",
                            "default": true
                        },
                        "modifierStat": {
                            "type": "string",
                            "enum": ["str", "dex", "con", "int", "wis", "cha"]
                        }
                    },
                    "required": ["base", "modifierStat"]
                },
                "onSave": {
                    "type": "string",
                    "enum": ["half_damage", "no_damage", "special"]
                }
            },
            "required": ["ability", "dcCalculation", "onSave"]
        },
        "output": {
            "type": "object",
            "description": "What happens when the action connects.",
            "properties": {
                "damage": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "type": {
                                "type": "string",
                                "description": "e.g., 'fire', 'slashing', 'radiant'"
                            },
                            "roll": {
                                "type": "string",
                                "description": "Base dice pool (e.g., '2d6')"
                            },
                            "addModifier": {
                                "type": "boolean",
                                "description": "True if you add the attack ability modifier to the damage (like standard weapons)."
                            },
                            "scaling": {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": ["character_level", "class_level", "spell_slot"]
                                    },
                                    "thresholds": {
                                        "type": "object",
                                        "additionalProperties": {
                                            "type": "string"
                                        },
                                        "description": "e.g., { '6': '3d6', '11': '4d6' }"
                                    }
                                }
                            }
                        },
                        "required": ["type", "roll"]
                    }
                },
                "healing": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "description": "IDs referencing temporary buffs and debuffs"
                    }
                }
            }
        }
    },
    "required": ["id", "name", "activation", "range"]
}