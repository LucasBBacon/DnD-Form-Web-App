{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "DnD Trait",
    "type": "object",
    "definitions": {
        "predicate": {
            "type": "object",
            "description": "A predicate used to conditionally apply a trait effect.",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "Predicate evaluation type."
                },
                "value": {
                    "type": [
                        "string",
                        "number",
                        "boolean"
                    ],
                    "description": "Value used by the predicate comparison."
                },
                "target": {
                    "type": "string",
                    "description": "The predicate target (e.g., 'str', 'trait_darkvision')."
                }
            },
            "required": [
                "type"
            ],
            "additionalProperties": false
        }
    },
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^trait_[a-z0-9_]+$",
            "description": "Unique identifier for the trait."
        },
        "name": {
            "type": "string",
            "description": "Display name of the trait."
        },
        "lore": {
            "type": "object",
            "description": "Flavor text and short description shown in the UI.",
            "properties": {
                "short_description": {
                    "type": "string",
                    "description": "A short description for list views and tooltips."
                },
                "full_text": {
                    "type": "string",
                    "description": "Optional extended text for detail views."
                }
            },
            "required": [
                "short_description"
            ],
            "additionalProperties": false
        },
        "effects": {
            "type": "array",
            "description": "Mechanical effects granted by this trait.",
            "items": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "advantage",
                            "disadvantage",
                            "sense",
                            "proficiency",
                            "half_proficiency",
                            "expertise",
                            "spell_grant",
                            "stat_modifier",
                            "ac_calculation",
                            "proficiency_choice",
                            "other"
                        ],
                        "description": "The kind of effect this entry applies."
                    },
                    "level_available": {
                        "type": "integer",
                        "description": "Character level required before this effect applies."
                    },
                    "target": {
                        "type": "string",
                        "description": "What this effect modifies; for spell_grant this is typically a spell id."
                    },
                    "value": {
                        "type": [
                            "boolean",
                            "string",
                            "integer",
                            "number"
                        ]
                    },
                    "spellcasting_ability": {
                        "type": "string",
                        "enum": [
                            "str",
                            "dex",
                            "con",
                            "int",
                            "wis",
                            "cha"
                        ],
                        "description": "The ability score used for a granted spell."
                    },
                    "uses": {
                        "type": "object",
                        "description": "How many times the effect can be used and when it resets.",
                        "properties": {
                            "count": {
                                "type": [
                                    "number",
                                    "string"
                                ],
                                "description": "Use count, or a scaling key when represented as a string."
                            },
                            "reset": {
                                "type": "string",
                                "enum": [
                                    "short_rest",
                                    "long_rest",
                                    "turn",
                                    "other"
                                ],
                                "description": "When the use count resets."
                            }
                        },
                        "required": [
                            "count",
                            "reset"
                        ],
                        "additionalProperties": false
                    },
                    "predicates": {
                        "type": "array",
                        "description": "Optional conditions that all need to pass for this effect to apply.",
                        "items": {
                            "$ref": "#/definitions/predicate"
                        }
                    },
                    "choice": {
                        "type": "object",
                        "description": "Optional selection when the effect requires choosing from a pool of options.",
                        "properties": {
                            "count": {
                                "type": "number",
                                "description": "The number of items to choose from the pool."
                            },
                            "pool": {
                                "anyOf": [
                                    {
                                        "type": "string",
                                        "enum": [
                                            "any"
                                        ],
                                        "description": "Allow any option."
                                    },
                                    {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "description": "A specific list of pool IDs (e.g., skill names or trait IDs)."
                                    }
                                ]
                            }
                        },
                        "required": [
                            "count",
                            "pool"
                        ],
                        "additionalProperties": false
                    }
                },
                "required": [
                    "type"
                ],
                "additionalProperties": false
            }
        }
    },
    "required": [
        "id",
        "name",
        "lore"
    ],
    "additionalProperties": false
}