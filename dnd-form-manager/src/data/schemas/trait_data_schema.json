{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "DnD Trait",
    "type": "object",
    "definitions": {
        "predicate": {
            "oneOf": [
                {
                    "type": "object",
                    "description": "Require equipped armor of a specific type or any",
                    "properties": {
                        "type": {
                            "type": "string",
                            "const": "armor_required"
                        },
                        "value": {
                            "type": "string",
                            "enum": [
                                "heavy",
                                "light",
                                "medium",
                                "shield",
                                "any"
                            ],
                            "description": "Armor category required."
                        }
                    },
                    "required": [
                        "type",
                        "value"
                    ],
                    "additionalProperties": false
                },
                {
                    "type": "object",
                    "description": "Prohibit equipped armor of a specific type, or any armor at all.",
                    "properties": {
                        "type": {
                            "type": "string",
                            "const": "armor_prohibited"
                        },
                        "value": {
                            "type": "string",
                            "enum": [
                                "heavy",
                                "light",
                                "medium",
                                "shield",
                                "any"
                            ],
                            "description": "Armor category prohibited, or 'any' to prohibit all armor."
                        }
                    },
                    "required": [
                        "type",
                        "value"
                    ],
                    "additionalProperties": false
                },
                {
                    "type": "object",
                    "description": "Prohibit equipping a shield.",
                    "properties": {
                        "type": {
                            "type": "string",
                            "const": "shield_prohibited"
                        },
                        "value": {
                            "type": "boolean",
                            "description": "true = shield must NOT be equipped; false = shield must be equipped."
                        }
                    },
                    "required": [
                        "type",
                        "value"
                    ],
                    "additionalProperties": false
                },
                {
                    "type": "object",
                    "description": "Require a minimum ability score.",
                    "properties": {
                        "type": {
                            "type": "string",
                            "const": "stat_minimum"
                        },
                        "target": {
                            "type": "string",
                            "enum": [
                                "str",
                                "dex",
                                "con",
                                "int",
                                "wis",
                                "cha"
                            ],
                            "description": "Ability score to check."
                        },
                        "value": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 30,
                            "description": "Minimum score required (inclusive)."
                        }
                    },
                    "required": [
                        "type",
                        "target",
                        "value"
                    ],
                    "additionalProperties": false
                },
                {
                    "type": "object",
                    "description": "Require a specific trait to be active on the character.",
                    "properties": {
                        "type": {
                            "type": "string",
                            "const": "requires_trait"
                        },
                        "target": {
                            "type": "string",
                            "pattern": "^trait_[a-z0-9_]+$",
                            "description": "Trait ID required (e.g., 'trait_spellcasting')."
                        }
                    },
                    "required": [
                        "type",
                        "target"
                    ]
                },
                {
                    "type": "object",
                    "description": "Gate an effect on an environmental condition (not currently evaluated at runtime).",
                    "properties": {
                        "type": {
                            "type": "string",
                            "const": "environment_condition"
                        },
                        "value": {
                            "type": "string",
                            "description": "Environment condition identifier (e.g., 'dim_light')."
                        }
                    },
                    "required": [
                        "type",
                        "value"
                    ],
                    "additionalProperties": false
                },
                {
                    "type": "object",
                    "description": "Require any equipped weapon to have a specific property or be of the ranged category.",
                    "properties": {
                        "type": {
                            "type": "string",
                            "const": "weapon_property"
                        },
                        "target": {
                            "type": "string",
                            "enum": [
                                "finesse",
                                "light",
                                "heavy",
                                "two-handed",
                                "thrown",
                                "ammunition",
                                "versatile",
                                "reach",
                                "ranged"
                            ],
                            "description": "Weapon property or category token to match."
                        }
                    },
                    "required": [
                        "type",
                        "target"
                    ],
                    "additionalProperties": false
                }
            ]
        }
    },
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^trait_[a-z0-9_]+$",
            "description": "Unique identifier for the trait."
        },
        "name": {
            "type": "string",
            "description": "Display name of the trait."
        },
        "lore": {
            "type": "object",
            "description": "Flavor text and short description shown in the UI.",
            "properties": {
                "shortDescription": {
                    "type": "string",
                    "description": "A short description for list views and tooltips."
                },
                "fullText": {
                    "type": "string",
                    "description": "Optional extended text for detail views."
                }
            },
            "required": [
                "shortDescription"
            ],
            "additionalProperties": false
        },
        "effects": {
            "type": "array",
            "description": "Mechanical effects granted by this trait.",
            "items": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "advantage",
                            "disadvantage",
                            "resistance",
                            "sense",
                            "proficiency",
                            "save_proficiency",
                            "half_proficiency",
                            "expertise",
                            "spell_grant",
                            "stat_modifier",
                            "ability_bonus_fixed",
                            "ability_bonus_choice",
                            "size_set",
                            "ac_calculation",
                            "proficiency_choice",
                            "language_grant",
                            "language_choice",
                            "other"
                        ],
                        "description": "The kind of effect this entry applies."
                    },
                    "levelAvailable": {
                        "type": "integer",
                        "description": "Character level required before this effect applies."
                    },
                    "target": {
                        "type": "string",
                        "description": "What this effect modifies; for spell_grant this is typically a spell id."
                    },
                    "value": {
                        "type": [
                            "boolean",
                            "string",
                            "integer",
                            "number"
                        ]
                    },
                    "spellcastingAbility": {
                        "type": "string",
                        "enum": [
                            "str",
                            "dex",
                            "con",
                            "int",
                            "wis",
                            "cha"
                        ],
                        "description": "The ability score used for a granted spell."
                    },
                    "uses": {
                        "type": "object",
                        "description": "How many times the effect can be used and when it resets.",
                        "properties": {
                            "count": {
                                "type": [
                                    "number",
                                    "string"
                                ],
                                "description": "Use count, or a scaling key when represented as a string."
                            },
                            "reset": {
                                "type": "string",
                                "enum": [
                                    "short_rest",
                                    "long_rest",
                                    "turn",
                                    "other"
                                ],
                                "description": "When the use count resets."
                            }
                        },
                        "required": [
                            "count",
                            "reset"
                        ],
                        "additionalProperties": false
                    },
                    "predicates": {
                        "type": "array",
                        "description": "Optional conditions that all need to pass for this effect to apply.",
                        "items": {
                            "$ref": "#/definitions/predicate"
                        }
                    },
                    "choice": {
                        "type": "object",
                        "description": "Optional selection when the effect requires choosing from a pool of options.",
                        "properties": {
                            "count": {
                                "type": "number",
                                "description": "The number of items to choose from the pool."
                            },
                            "bonus": {
                                "type": "number",
                                "description": "Bonus value to apply for each selected choice, used by ability_bonus_choice effects."
                            },
                            "pool": {
                                "anyOf": [
                                    {
                                        "type": "string",
                                        "enum": [
                                            "any"
                                        ],
                                        "description": "Allow any option."
                                    },
                                    {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "description": "A specific list of pool IDs (e.g., skill names or trait IDs)."
                                    }
                                ]
                            }
                        },
                        "required": [
                            "count",
                            "pool"
                        ],
                        "additionalProperties": false
                    }
                },
                "required": [
                    "type"
                ],
                "additionalProperties": false
            }
        }
    },
    "required": [
        "id",
        "name",
        "lore"
    ],
    "additionalProperties": false
}