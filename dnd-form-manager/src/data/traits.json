    "name": "Unarmored Defense",
    "effects": [
      {
        "type": "stat_modifier",
        "target": "ac",
        "value": "con",
        "predicates": [
          {
            "type": "armor_prohibited",
            "value": "any"
          },
          {
            "type": "shield_prohibited",
            "value": true
          }
        ]
      }
    ],
    "lore": {
      "short_description": "While you are not wearing any armor, your Armor Class equals 10 + your Dexterity modifier + your Constitution modifier. Vou can use a shield and still gain this benefit.",
      "full_text": "While you are not wearing any armor, your Armor Class equals 10 + your Dexterity modifier + your Constitution modifier. Vou can use a shield and still gain this benefit."
    }
