    "json.schemas": [

        {
            "fileMatch": [
                "races/*_race.json"
            ],
            "url": "./dnd-form-manager/src/data/schemas/race_data_schema.json"
        },
        {
            "fileMatch": [
                "classes/*_class.json"
            ],
            "url": "./dnd-form-manager/src/data/schemas/class_data_schema.json"
        },
        {
            "fileMatch": [
                "subraces/*_subrace.json"
            ],
            "url": "./dnd-form-manager/src/data/schemas/subrace_data_schema.json"
        },
        {
            "fileMatch": [
                "subclasses/*_subclass.json"
            ],
            "url": "./dnd-form-manager/src/data/schemas/subclass_data_schema.json"
        },
        {
            "fileMatch": [
                "traits/*_trait.json",
                "traits/**/*_trait.json"
            ],
            "url": "./dnd-form-manager/src/data/schemas/trait_data_schema.json"
        },
        {
            "fileMatch": [
                "spells/*_spell.json"
            ],
            "url": "/dnd-form-manager/src/data/schemas/spell_data_schema.json"
        },
        {
            "fileMatch": [
                "actions/*_action.json"
            ],
            "url": "/dnd-form-manager/src/data/schemas/action_data_schema.json"
        }
